; AI invoke strategy & provider
LLM_PROVIDERS=doubao,deepseek
LLM_ROUTING_STRATEGY=cheapest_first

; Doubao config
DOUBAO_API_KEY=ark-xxx
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=doubao-seed-2-0-code-preview-260215
DOUBAO_LATENCY_MS=300

; DeepSeek config
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_LATENCY_MS=500

; Claude config
CLAUDE_API_KEY=sk-xxx
CLAUDE_BASE_URL=https://api.anthropic.com
CLAUDE_MODEL=claude-3-5-sonnet-latest
CLAUDE_LATENCY_MS=800